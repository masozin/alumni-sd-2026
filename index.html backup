            </svg>
          </button>

          <button class="nb" id="nBtn" title="Selanjutnya (→)">&#10095;</button>
        </div>

        <p class="hint">
          ← → Navigasi &nbsp;·&nbsp; Spasi Auto-play &nbsp;·&nbsp; F Flip Foto
          &nbsp;·&nbsp; F11 Fullscreen
        </p>
      </div>
    </div>

    <button
      id="nav-toggle"
      class="nav-toggle-btn"
      aria-label="Buka Daftar Siswa"
    >
      <span class="arrow-icon">‹</span>
    </button>

    <div id="student-sidebar" class="student-sidebar">
      <div class="sidebar-header">
        <h3>Daftar Siswa</h3>
        <button id="sidebar-close" class="sidebar-close-btn">&times;</button>
      </div>
      <ul id="sidebar-list" class="sidebar-list"></ul>
    </div>

    <div id="sidebar-overlay" class="sidebar-overlay"></div>

    <script>
      /* ── STARFIELD ── */
      (function () {
        const c = document.getElementById("cv"),
          ctx = c.getContext("2d");
        let W,
          H,
          stars = [];
        function rsz() {
          W = c.width = innerWidth;
          H = c.height = innerHeight;
        }
        function mk() {
          return {
            x: Math.random() * W,
            y: Math.random() * H,
            r: Math.random() * 1.4 + 0.25,
            a: Math.random(),
            da: (Math.random() - 0.5) * 0.007,
            vy: Math.random() * 0.13 + 0.04,
            gold: Math.random() < 0.13,
          };
        }
        function init() {
          stars = Array.from({ length: 190 }, mk);
        }
        function draw() {
          ctx.clearRect(0, 0, W, H);
          stars.forEach((s) => {
            s.a += s.da;
            if (s.a <= 0 || s.a >= 1) s.da *= -1;
            s.y -= s.vy;
            if (s.y + s.r < 0) {
              s.y = H + s.r;
              s.x = Math.random() * W;
            }
            ctx.save();
            ctx.globalAlpha = s.a * 0.9;
            ctx.fillStyle = s.gold ? "#F5D780" : "#FFFFFF";
            ctx.beginPath();
            ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
          });
          requestAnimationFrame(draw);
        }
        rsz();
        init();
        draw();
        window.addEventListener("resize", () => {
          rsz();
          init();
        });
      })();

      /* ── DATA ── */
      const GRADS = [
        ["#0c1a3a", "#0d3d68"],
        ["#180c3a", "#2a1265"],
        ["#0c321c", "#0c5430"],
        ["#2a1800", "#563200"],
        ["#0c3535", "#0c5050"],
        ["#270c34", "#4c0e62"],
        ["#001828", "#003252"],
        ["#261200", "#4e2700"],
      ];

      let students = [],
        cur = 0,
        transitioning = false,
        navDir = "next";
      let ap = false,
        tRaf = null,
        tStart = null,
        tElapsed = 0;
      const AUTO = 15000,
        CIRC = 2 * Math.PI * 16.5;
      const flipState = {};

      async function load() {
        try {
          const r = await fetch("data.json");
          students = await r.json();
        } catch {
          // Roster fallback jika file data.json gagal dimuat
          students = [
            {
              nama: "Ahmad Fauzi",
              ttl: "Palembang, 15 Maret 2014",
              namaAyah: "Budi Santoso",
              namaIbu: "Sri Wahyuni",
              citaCita: "Dokter Spesialis Anak",
              pesan: "Jadilah orang yang bermanfaat bagi sesama.",
              foto: "...",
              fotoCita: "...",
            },
            {
              nama: "Siti Rahmawati",
              ttl: "Totorejo, 22 Juli 2014",
              namaAyah: "Rahmat Hidayat",
              namaIbu: "Nurul Fadilah",
              citaCita: "Guru Bahasa Inggris",
              pesan: "Terus belajar dan jangan pernah menyerah.",
              foto: "...",
              fotoCita: "...",
            },
          ];
        }

        // PUSH SLIDE PENUTUP EXCLUSIVE KE AKHIR ARRAY
        students.push({
          isPenutup: true,
        });

        // Jalankan render bawaan kode kamu
        renderCards();
        buildDots();
        show(0, true);
        if (typeof renderSidebarNav === "function") {
          renderSidebarNav();
        }

        // setTimeout(() => autoFlipActive(), 7000);
      }

      /* ── BUILD ── */
      function renderCards() {
        const vp = document.getElementById("vp");
        vp.innerHTML = "";

        students.forEach((s, i) => {
          const el = document.createElement("div");
          el.className = "card";

          // PERIKSA: Jika ini slide penutup, gunakan template profesional yang berbeda
          if (s.isPenutup) {
            el.classList.add("card-penutup");
            el.innerHTML = `
        <div class="penutup-content ai" style="animation-delay:.15s">
          <div class="penutup-badge">Masa Depan Menanti</div>
          <h2 class="penutup-title">Terima Kasih</h2>
          <div class="penutup-divider">
            <span class="p-line"></span>
            <span class="p-diamond">&#10022;</span>
            <span class="p-line"></span>
          </div>
          <p class="penutup-quote">
            "Masa depan adalah milik mereka yang percaya pada keindahan impian mereka. Teruslah melangkah, jagalah api semangat belajarmu, dan jadilah kebanggaan bagi nusa dan bangsa."
          </p>
          <div class="penutup-footer">
            <p class="sch-name">SD Negeri 01 Totorejo</p>
            <p class="sch-year">Tahun Ajaran 2025/2026</p>
          </div>
        </div>
      `;
          } else {
            // TEMPLATE BAWAAN UNTUK SISWA BIASA
            el.innerHTML = `
        <div class="cp">
          <div class="photo-wrap">
            <div class="orbit"></div>
            <div class="ring-spin"></div>
            <div class="flip-scene" data-fi="${i}" title="Klik untuk lihat masa depan ✨">
              <div class="flip-front">
                <img src="${s.foto}" alt="${s.nama}" onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(s.nama)}&fontSize=38'">
              </div>
              <div class="flip-back">
                <img src="${s.fotoCita || s.foto}" alt="${s.nama} — ${s.citaCita}" onerror="this.src='https://api.dicebear.com/7.x/initials/svg?seed=${encodeURIComponent(s.nama + " Cita-cita")}&backgroundColor=0d3d68&textColor=f5d780&fontSize=38'">
              </div>
            </div>
            <div class="photo-badge">
              <div class="pb-dot pa" data-pi="${i}" data-side="0" title="Foto sekarang"></div>
              <div class="pb-dot" data-pi="${i}" data-side="1" title="Foto masa depan"></div>
            </div>
            <div class="photo-label" id="plbl-${i}">Foto Sekarang</div>
          </div>
        </div>
        <div class="cdv"></div>
        <div class="ci">
          <h2 class="sname ai" style="animation-delay:.05s">${s.nama}</h2>
          <p class="sttl ai" style="animation-delay:.13s">${s.ttl}</p>
          <div class="sdiv ai" style="animation-delay:.5s"></div>
          <div class="itbl">
            <div class="irow ai" style="animation-delay:.5s">
              <span class="ilbl">Nama Ayah</span><span class="idot">&#9670;</span><span class="ival">${s.namaAyah}</span>
            </div>
            <div class="irow ai" style="animation-delay:.34s">
              <span class="ilbl">Nama Ibu</span><span class="idot">&#9670;</span><span class="ival">${s.namaIbu}</span>
            </div>
          </div>
          <div class="db ai" style="animation-delay:.42s">
            <p class="dtag">&#10022; Cita-cita</p>
            <p class="dval">${s.citaCita}</p>
            <p class="mtag">&#10022; Pesan</p>
            <p class="mval">"${s.pesan}"</p>
          </div>
        </div>
      `;
          }
          vp.appendChild(el);
        });

        // Pasang kembali event listener flip khusus slide siswa biasa
        document.querySelectorAll(".flip-scene").forEach((fs) => {
          fs.addEventListener("click", () => doFlip(parseInt(fs.dataset.fi)));
        });
        document.querySelectorAll(".pb-dot").forEach((d) => {
          d.addEventListener("click", (e) => {
            e.stopPropagation();
            const idx = parseInt(d.dataset.pi),
              side = parseInt(d.dataset.side);
            if (flipState[idx] !== (side === 1)) doFlip(idx);
          });
        });
      }

      /* ── REFACTOR FUNGSI FLIP (Bebas Patah-Patah) ── */
      /* ── FUNGSI FADE SUPER RINGAN ── */
      function doFlip(idx) {
        flipState[idx] = !flipState[idx];
        const flipped = flipState[idx];
        const scene = document.querySelector(`.flip-scene[data-fi="${idx}"]`);
        const lbl = document.getElementById(`plbl-${idx}`);
        const dots = document.querySelectorAll(`.pb-dot[data-pi="${idx}"]`);

        if (!scene) return;

        // Terapkan efek fade lewat CSS class
        scene.classList.toggle("flipped", flipped);

        // Ganti teks label dengan efek memudar menyesuaikan durasi foto
        if (lbl) {
          lbl.style.opacity = "0";
          setTimeout(() => {
            lbl.textContent = flipped ? "Foto Masa Depan ✦" : "Foto Sekarang";
            lbl.style.opacity = "1";
          }, 1000); // Teks berganti tepat di pertengahan efek fade
        }

        // Pindahkan indikator titik aktif
        dots.forEach((d, i) =>
          d.classList.toggle("pa", flipped ? i === 1 : i === 0),
        );
      }

      function autoFlipActive() {
        // Jika saat ini berada di slide penutup, hentikan proses auto-flip foto
        if (students[cur] && students[cur].isPenutup) return;

        // Otomatis membalik ke "Foto Cita-cita" jika saat ini masih "Foto Sekarang"
        if (!flipState[cur]) {
          doFlip(cur);
        }
      }

      /* ── TILT ── */
      function tilt(e) {
        const c = e.currentTarget,
          r = c.getBoundingClientRect();
        const mx = (e.clientX - r.left) / r.width - 0.5,
          my = (e.clientY - r.top) / r.height - 0.5;
        c.style.transform = `perspective(1200px) rotateY(${mx * 7}deg) rotateX(${-my * 5}deg) scale(1.012)`;
        c.style.transition = "transform .12s ease";
      }
      function untilt(e) {
        e.currentTarget.style.transform = "";
        e.currentTarget.style.transition = "transform .6s ease";
      }

      /* ── DOTS ── */
      function buildDots() {
        const el = document.getElementById("dotsEl");
        el.innerHTML = "";
        if (students.length <= 16) {
          students.forEach((_, i) => {
            const d = document.createElement("div");
            d.className = "dot";
            d.addEventListener("click", () => goto(i));
            el.appendChild(d);
          });
        }
      }
      function updDots() {
        document
          .querySelectorAll(".dot")
          .forEach((d, i) => d.classList.toggle("a", i === cur));
        document.getElementById("cntEl").textContent =
          `${cur + 1} / ${students.length}`;
      }

      /* ── SHOW ── */
      function show(idx, init = false) {
        const cards = document.querySelectorAll(".card");
        cards.forEach((c, i) => {
          if (i === idx) {
            c.classList.remove(
              "to-left",
              "to-right",
              "from-right",
              "from-left",
            );
            if (!init) {
              c.classList.add(navDir === "next" ? "from-right" : "from-left");
              void c.offsetWidth;
            }
            c.classList.add("active");
            replayAnim(c);
            if (flipState[i] === true) {
              flipState[i] = false;
              resetFlip(i);
            }
            setTimeout(() => {
              if (cur === i) autoFlipActive();
            }, 7000);
          } else {
            c.classList.remove("active", "from-right", "from-left");
          }
        });
        updDots();
      }
      function resetFlip(idx) {
        const scene = document.querySelector(`.flip-scene[data-fi="${idx}"]`);
        const lbl = document.getElementById(`plbl-${idx}`);
        const dots = document.querySelectorAll(`.pb-dot[data-pi="${idx}"]`);
        if (scene) scene.classList.remove("flipped");
        if (lbl) {
          // Jika slide penutup gunakan teks "Pelepasan VI", jika siswa gunakan "Foto Sekarang"
          lbl.textContent =
            students[idx] && students[idx].isPenutup
              ? "Pelepasan VI"
              : "Foto Sekarang";
        }
        dots.forEach((d, i) => d.classList.toggle("pa", i === 0));
      }
      function replayAnim(card) {
        card.querySelectorAll(".ai").forEach((el) => {
          el.style.animation = "none";
          void el.offsetHeight;
          el.style.animation = "";
        });
      }

      /* ── NAVIGATE ── */
      function goto(idx) {
        if (transitioning || idx === cur) return;
        transitioning = true;
        navDir = idx > cur ? "next" : "prev";
        const prev = cur;
        cur = idx;
        // const fl = document.getElementById("flash");
        // fl.style.transition = "none";
        // fl.style.opacity = "1";
        // setTimeout(() => {
        //   fl.style.transition = "opacity 0.5s ease";
        //   fl.style.opacity = "0";
        // }, 1500);
        const cards = document.querySelectorAll(".card");
        cards[prev].classList.remove("active");
        cards[prev].classList.add(navDir === "next" ? "to-left" : "to-right");
        setTimeout(() => {
          cards[prev].classList.remove("to-left", "to-right");
          transitioning = false;
        }, 2500);
        setTimeout(() => show(cur), 1000);
        if (ap) restartTimer();
      }
      function chg(d) {
        const n = students.length;
        let nextIdx = cur + d;

        // ── TAMBAHAN BARU: Jika sudah di slide akhir dan mencoba maju lagi ──
        if (nextIdx >= n) {
          if (ap) toggleAP(); // Otomatis matikan Autoplay (berhenti berputar)
          return; // Berhenti di sini, jangan biarkan kembali ke awal
        }

        // Proteksi jika menekan tombol kembali di slide pertama agar tidak loop ke akhir
        if (nextIdx < 0) {
          return;
        }

        goto(nextIdx);
        if (typeof updateSidebarActive === "function") {
          updateSidebarActive();
        }
      }

      /* ── AUTOPLAY ── */
      const tfEl = document.getElementById("tfEl"),
        tiEl = document.getElementById("tiEl");
      tfEl.style.strokeDasharray = CIRC;
      tfEl.style.strokeDashoffset = CIRC;
      function toggleAP() {
        ap = !ap;
        tiEl.innerHTML = ap ? "&#9646;&#9646;" : "&#9654;";
        if (ap) startTimer();
        else {
          stopTimer();
          tfEl.style.strokeDashoffset = CIRC;
        }
      }
      function startTimer() {
        tStart = performance.now() - tElapsed;
        tRaf = requestAnimationFrame(tickTimer);
      }
      function stopTimer() {
        if (tRaf !== null) {
          cancelAnimationFrame(tRaf);
          tRaf = null;
        }
      }
      function restartTimer() {
        stopTimer();
        tElapsed = 0;
        tfEl.style.strokeDashoffset = CIRC;
        if (ap) startTimer();
      }
      function tickTimer() {
        const now = performance.now();
        tElapsed = now - tStart;
        const p = Math.min(tElapsed / AUTO, 1);
        tfEl.style.strokeDashoffset = CIRC * (1 - p);
        if (p >= 1) {
          chg(1);
          //   tElapsed = 0;
          //   tStart = performance.now();
          //   tRaf = requestAnimationFrame(tickTimer);
          return;
        }
        if (ap) {
          tRaf = requestAnimationFrame(tickTimer);
        }
      }
      document.getElementById("trEl").addEventListener("click", toggleAP);

      /* ════════════════════════════════════════
         ── FULLSCREEN ──
         Shortcut : F11  (keyboard)
         Tombol   : fsBtn (klik)
      ════════════════════════════════════════ */
      const fsBtn = document.getElementById("fsBtn");
      const fsIcon = document.getElementById("fsIcon");
      const fsToast = document.getElementById("fs-toast");

      /* SVG paths untuk dua state */
      const ICON_ENTER = "M1 5V1h4M10 1h4v4M14 10v4h-4M5 14H1v-4"; /* expand */
      const ICON_EXIT = "M5 1v4H1M9 1v4h4M9 13v-4h4M5 13v-4H1"; /* compress */

      let toastTimer = null;
      function showToast(msg) {
        fsToast.textContent = msg;
        fsToast.classList.add("show");
        clearTimeout(toastTimer);
        toastTimer = setTimeout(() => fsToast.classList.remove("show"), 2200);
      }

      function updateFsIcon() {
        const isFs = !!document.fullscreenElement;
        fsIcon
          .querySelector("path")
          .setAttribute("d", isFs ? ICON_EXIT : ICON_ENTER);
        fsBtn.title = isFs
          ? "Keluar Fullscreen (F11 / Esc)"
          : "Fullscreen (F11)";
      }

      function toggleFullscreen() {
        if (!document.fullscreenElement) {
          document.documentElement
            .requestFullscreen({ navigationUI: "hide" })
            .then(() => showToast("✦ Fullscreen — tekan Esc untuk keluar"))
            .catch(() => showToast("Fullscreen tidak didukung browser ini"));
        } else {
          document.exitFullscreen().then(() => showToast("Keluar Fullscreen"));
        }
      }

      fsBtn.addEventListener("click", toggleFullscreen);

      document.addEventListener("fullscreenchange", updateFsIcon);
      document.addEventListener("webkitfullscreenchange", updateFsIcon);

      /* ── KEYBOARD ── */
      document.addEventListener("keydown", (e) => {
        if (e.key === "ArrowRight" || e.key === "ArrowDown") chg(1);
        else if (e.key === "ArrowLeft" || e.key === "ArrowUp") chg(-1);
        else if (e.key === " ") {
          e.preventDefault();
          toggleAP();
        } else if (e.key === "f" || e.key === "F") doFlip(cur);
        else if (e.key === "F11") {
          e.preventDefault();
          toggleFullscreen();
        }
      });

      /* ── TOUCH ── */
      let tx0 = 0;
      const vpEl = document.getElementById("vp");
      vpEl.addEventListener("touchstart", (e) => (tx0 = e.touches[0].clientX), {
        passive: true,
      });
      vpEl.addEventListener(
        "touchend",
        (e) => {
          const dx = e.changedTouches[0].clientX - tx0;
          if (Math.abs(dx) > 50) chg(dx < 0 ? 1 : -1);
        },
        { passive: true },
      );

      document.getElementById("pBtn").addEventListener("click", () => chg(-1));
      document.getElementById("nBtn").addEventListener("click", () => chg(1));

      load();

      /* ── LOGIKA SIDEBAR NAVIGATOR ── */
      const navToggle = document.getElementById("nav-toggle");
      const sidebar = document.getElementById("student-sidebar");
      const sidebarClose = document.getElementById("sidebar-close");
      const sidebarOverlay = document.getElementById("sidebar-overlay");
      const sidebarList = document.getElementById("sidebar-list");

      // Fungsi Buka / Tutup Menu
      function toggleSidebar() {
        const isOpen = sidebar.classList.toggle("open");
        sidebarOverlay.classList.toggle("open", isOpen);
        // Sembunyikan tombol kecil pemicu saat menu terbuka agar bersih
        navToggle.style.transform = isOpen
          ? "translateY(-50%) translateX(100%)"
          : "translateY(-50%)";
      }

      navToggle.addEventListener("click", toggleSidebar);
      sidebarClose.addEventListener("click", toggleSidebar);
      sidebarOverlay.addEventListener("click", toggleSidebar);

      // Render Otomatis Nama Siswa ke Sidebar
      function renderSidebarNav() {
        sidebarList.innerHTML = "";

        // Menggunakan variabel 'students' sesuai dengan kode Anda
        if (typeof students !== "undefined" && Array.isArray(students)) {
          students.forEach((item, idx) => {
            // ── TAMBAHAN BARU: Skip slide penutup agar tidak muncul di daftar nama siswa ──
            if (item.isPenutup) return;

            const li = document.createElement("li");
            li.textContent = item.nama || `Siswa ${idx + 1}`;
            li.setAttribute("data-idx", idx);

            if (idx === cur) li.classList.add("active");

            // Mekanisme Lompat ke Foto Siswa Pilihan
            li.addEventListener("click", () => {
              if (idx !== cur) {
                const diff = idx - cur;
                chg(diff); // Memanggil fungsi perubahan slide bawaan kode Anda
              }
              toggleSidebar(); // Otomatis tutup sidebar setelah memilih
            });

            sidebarList.appendChild(li);
          });
        }
      }

      // Fungsi untuk meng-update status 'active' di sidebar saat user klik tombol next/prev bawaan
      function updateSidebarActive() {
        const items = sidebarList.querySelectorAll("li");
        items.forEach((item, idx) => {
          item.classList.toggle("active", idx === cur);
        });
      }

      /* ══════════════════════════════════════════════════════
   ── CONTROLLER GERBANG UTAMA & AUTOMATIC INTRO ──
   ══════════════════════════════════════════════════════ */
      document.addEventListener("DOMContentLoaded", () => {
        const welcomeScreen = document.getElementById("welcomeScreen");
        const welcomeBtn = document.getElementById("welcomeBtn");
        const introScreen = document.getElementById("introScreen");

        if (welcomeBtn && welcomeScreen && introScreen) {
          welcomeBtn.addEventListener("click", () => {
            // 1. Hilangkan gerbang utama, layar Intro langsung aktif di belakangnya
            welcomeScreen.classList.add("hidden");

            // TIPS OPTIONAL: Jika Anda punya file audio musik latar, jalankan di sini!
            // contoh: let lagu = new Audio('audio/backsound.mp3'); lagu.play();

            // 2. TIMING OTOMATIS: Biarkan animasi teks intro berjalan sendiri tanpa tombol
            // Angka 4500 artinya intro tampil selama 4,5 detik sebelum pindah otomatis ke slide.
            // Anda bebas mengubah durasi ini (dalam milidetik) sesuai panjang teks intro Anda.
            setTimeout(() => {
              // Jalankan transisi memudarnya tirai pembuka secara otomatis
              introScreen.classList.add("hidden");

              // Picu transisi cinematic masuk untuk Slide Pertama (Kartu Siswa ke-1)
              setTimeout(() => {
                document.body.classList.add("app-ready");
              }, 250);

              // Hapus elemen sampah agar tidak memperberat memori browser
              setTimeout(() => {
                introScreen.remove();
                welcomeScreen.remove();
              }, 1400);

              // Aktifkan Fitur Autoplay pergantian slide otomatis
              if (
                typeof toggleAP === "function" &&
                typeof ap !== "undefined" &&
                !ap
              ) {
                setTimeout(() => {
                  toggleAP();
                }, 1500);
              }
            }, 4500); // <── ATUR DURASI INTRO DI SINI (4500 = 4,5 Detik)
          });
        }
      });
    </script>
  </body>
</html>
