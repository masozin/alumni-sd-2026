<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pelepasan Kelas VI — SDN 01 Totorejo 2026</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --gold: #d4a943;
        --gold-lt: #f5d780;
        --gold-dk: #8b6914;
        --glow: rgba(212, 169, 67, 0.28);
        --bg: #06091a;
        --bg2: #0e1628;
        --card: rgba(10, 18, 40, 0.92);
        --w: #f5f0e8;
        --wd: rgba(245, 240, 232, 0.55);
        --wm: rgba(245, 240, 232, 0.85);
      }
      *,
      *::before,
      *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html,
      body {
        width: 100%;
        height: 100%;
        overflow: hidden;
      }
      body {
        font-family: "DM Sans", sans-serif;
        background: var(--bg);
        color: var(--w);
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      #cv {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      .aurora {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background:
          radial-gradient(
            ellipse 70% 50% at 15% 65%,
            rgba(80, 40, 180, 0.12) 0%,
            transparent 70%
          ),
          radial-gradient(
            ellipse 55% 40% at 85% 25%,
            rgba(212, 169, 67, 0.07) 0%,
            transparent 70%
          ),
          radial-gradient(
            ellipse 50% 60% at 50% 100%,
            rgba(30, 80, 220, 0.09) 0%,
            transparent 70%
          );
      }

      .pg {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        padding: 22px 36px 16px;
      }

      header {
        text-align: center;
        animation: fadeD 0.9s ease both;
      }
      .badge {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        font-size: 0.88rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 5px;
      }
      .bl {
        width: 26px;
        height: 1px;
        background: var(--gold);
        opacity: 0.55;
      }
      header h1 {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2rem, 2.8vw, 3.8rem);
        font-weight: 700;
        letter-spacing: 0.04em;
        line-height: 1.2;
        background: linear-gradient(
          90deg,
          var(--gold-lt) 0%,
          var(--w) 20%,
          var(--gold) 40%,
          var(--w) 60%,
          var(--gold-lt) 80%,
          var(--w) 100%
        );
        background-size: 250% auto;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: shimmerText 20s linear infinite;
      }

      @keyframes shimmerText {
        0% {
          background-position: 200% center;
        }
        100% {
          background-position: -200% center;
        }
      }

      .sch {
        font-size: clamp(1.2rem, 1.8vw, 3rem);
        color: var(--wd);
        margin-top: 4px;
        letter-spacing: 0.08em;
      }
      .gl {
        width: 60px;
        height: 1px;
        margin: 8px auto 0;
        background: linear-gradient(
          90deg,
          transparent,
          var(--gold),
          transparent
        );
        opacity: 0.5;
      }

      .gl2 {
        width: 300px;
        height: 1px;
        margin: 8px auto 0;
        background: linear-gradient(
          90deg,
          transparent,
          var(--gold),
          transparent
        );
        opacity: 0.5;
      }

      .sz {
        display: flex;
        align-items: center;
        gap: 18px;
        width: 100%;
        max-width: 1160px;
        flex: 1;
        min-height: 0;
        padding: 10px 0;
      }

      .nb {
        width: 48px;
        height: 48px;
        flex-shrink: 0;
        border-radius: 50%;
        border: 1px solid rgba(212, 169, 67, 0.35);
        background: rgba(212, 169, 67, 0.07);
        color: var(--gold);
        font-size: 1rem;
        cursor: pointer;
        transition: all 0.25s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(12px);
        user-select: none;

        /* ── TAMBAHAN BARU: Membuat tombol melayang bebas di desktop ── */
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        z-index: 10;
      }
      .nb:hover {
        background: var(--gold);
        color: var(--bg);
        border-color: var(--gold);
        transform: scale(1.08);
        box-shadow: 0 0 22px var(--glow);
      }
      .nb:active {
        transform: scale(0.95);
      }

      /* ── TAMBAHAN BARU: Tentukan koordinat tombol Kiri & Kanan di desktop ── */
      #pBtn {
        left: 40px;
      }
      #nBtn {
        right: 40px;
      }

      .vp {
        flex: 1;
        height: 100%;
        position: relative;
        min-width: 0;
        perspective: 1200px;
      }

      .card {
        position: absolute;
        inset: 0;
        display: flex;
        border-radius: 22px;
        overflow: hidden;
        background: var(--card);
        backdrop-filter: blur(28px);
        -webkit-backdrop-filter: blur(28px);
        border: 1px solid rgba(212, 169, 67, 0.2);
        box-shadow:
          0 0 0 1px rgba(255, 255, 255, 0.03) inset,
          0 40px 80px rgba(0, 0, 0, 0.6);
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition:
          opacity 2.5s cubic-bezier(0.4, 0, 0.2, 1),
          transform 2.5s cubic-bezier(0.4, 0, 0.2, 1),
          visibility 2.5s;
        will-change: transform, opacity;
      }
      .card.from-right {
        transform: translateX(90px) scale(0.94);
        opacity: 0;
      }
      .card.from-left {
        transform: translateX(-90px) scale(0.94);
        opacity: 0;
      }
      .card.active {
        opacity: 0.7;
        visibility: visible;
        pointer-events: all;
        transform: translateX(0) scale(1);
        animation: borderPulse 5s ease 1.2s infinite;
      }
      .card.to-left {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateX(-90px) scale(0.94);
        transition-duration: 2.5s;
      }
      .card.to-right {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transform: translateX(90px) scale(0.94);
        transition-duration: 2.5s;
      }
      @keyframes borderPulse {
        0%,
        100% {
          border-color: rgba(212, 169, 67, 0.2);
        }
        50% {
          border-color: rgba(212, 169, 67, 0.5);
          box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.03) inset,
            0 40px 80px rgba(0, 0, 0, 0.6),
            0 0 40px rgba(212, 169, 67, 0.1);
        }
      }

      /* ── PHOTO SIDE ── */
      .cp {
        width: 42%;
        flex-shrink: 0;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
      }
      .cp::before {
        content: "";
        position: absolute;
        inset: 0;
        background-image: radial-gradient(
          circle,
          rgba(212, 169, 67, 0.05) 1px,
          transparent 1px
        );
        background-size: 22px 22px;
      }
      .cp::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 2px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--gold),
          transparent
        );
        opacity: 0.45;
      }

      .photo-wrap {
        position: relative;
        width: 300px;
        height: 300px;
        z-index: 1;
      }

      .orbit {
        position: absolute;
        inset: -12px;
        border-radius: 50%;
        border: 1px dashed rgba(212, 169, 67, 0.25);
        animation: spinA 20s linear infinite;
      }
      .orbit::before,
      .orbit::after {
        content: "";
        position: absolute;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--gold);
        top: 50%;
        transform: translateY(-50%);
      }
      .orbit::before {
        left: -3px;
      }
      .orbit::after {
        right: -3px;
      }
      @keyframes spinA {
        to {
          transform: rotate(360deg);
        }
      }

      .ring-spin {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        padding: 5px;
        background: conic-gradient(
          var(--gold-lt) 0deg,
          transparent 38deg,
          var(--gold) 76deg,
          transparent 114deg,
          var(--gold-lt) 152deg,
          transparent 190deg,
          var(--gold) 228deg,
          transparent 266deg,
          var(--gold-lt) 304deg,
          transparent 342deg,
          var(--gold-lt) 360deg
        );
        animation: spinA 9s linear infinite;
        filter: drop-shadow(0 0 9px rgba(212, 169, 67, 0.5));
      }

      /* ── REFACTOR FADE SCENE (Sangat Ringan & Elegan) ── */
      .flip-scene {
        width: calc(100% - 10px);
        height: calc(100% - 10px);
        position: absolute;
        inset: 5px;
        border-radius: 50%;
        cursor: pointer;
      }

      .flip-front,
      .flip-back {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        overflow: hidden;
        background: #070c1c;
        /* Menggunakan transisi opacity untuk fade yang sangat mulus */
        transition:
          opacity 2s ease,
          transform 2s ease;
      }

      /* Foto Sekarang (Tampil Default) */
      .flip-front {
        opacity: 1;
        transform: scale(1);
        z-index: 2;
      }

      /* Foto Cita-cita (Tersembunyi Default) */
      .flip-back {
        opacity: 0;
        /* Sedikit dibesarkan di awal biar efek masuknya terasa sinematik */
        transform: scale(1.15);
        z-index: 1;
        pointer-events: none;
      }

      .flip-front img,
      .flip-back img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
      }

      /* ── SAAT DIKLIK (Class .flipped aktif) ── */
      /* Foto Sekarang menghilang dan mengecil */
      .flip-scene.flipped .flip-front {
        opacity: 0;
        transform: scale(0.9);
        pointer-events: none;
      }

      /* Foto Cita-cita muncul pelan-pelan */
      .flip-scene.flipped .flip-back {
        opacity: 1;
        transform: scale(1);
        z-index: 3;
        pointer-events: all;
      }

      .photo-badge {
        position: absolute;
        bottom: -2px;
        left: 50%;
        transform: translateX(-50%);
        display: flex;
        align-items: center;
        gap: 5px;
        z-index: 10;
      }
      .pb-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        border: 1.5px solid rgba(212, 169, 67, 0.45);
        cursor: pointer;
        transition: all 0.3s ease;
        background: transparent;
      }
      .pb-dot.pa {
        background: var(--gold);
        border-color: var(--gold);
        box-shadow: 0 0 6px rgba(212, 169, 67, 0.7);
      }

      .sno {
        position: absolute;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.64rem;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--gold);
        white-space: nowrap;
        opacity: 0.75;
      }

      .photo-label {
        position: absolute;
        top: -45px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.6rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold-lt);
        background: rgba(6, 9, 26, 0.75);
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid rgba(212, 169, 67, 0.22);
        white-space: nowrap;
        pointer-events: none;
        transition: opacity 0.4s ease;
        backdrop-filter: blur(6px);
      }

      .pcv {
        position: absolute;
        inset: -30px;
        border-radius: 50%;
        pointer-events: none;
        z-index: 20;
      }

      .cdv {
        width: 1px;
        flex-shrink: 0;
        background: linear-gradient(
          to bottom,
          transparent,
          rgba(212, 169, 67, 0.28),
          transparent
        );
        align-self: stretch;
        margin: 36px 0;
      }

      .ci {
        flex: 1;
        padding: 34px 44px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        min-width: 0;
        overflow: hidden;
      }
      .ci::before {
        content: "";
        position: absolute;
        top: 0;
        right: 0;
        width: 120px;
        height: 120px;
        background: radial-gradient(
          circle at top right,
          rgba(212, 169, 67, 0.08) 0%,
          transparent 65%
        );
        border-radius: 0 22px 0 0;
        pointer-events: none;
      }
      .ci::after {
        content: "";
        position: absolute;
        bottom: 0;
        left: 0;
        width: 90px;
        height: 90px;
        background: radial-gradient(
          circle at bottom left,
          rgba(80, 40, 180, 0.07) 0%,
          transparent 65%
        );
        border-radius: 0 0 0 22px;
        pointer-events: none;
      }

      .ai {
        opacity: 0;
        transform: translateY(20px);
        animation: sup 0.6s ease forwards;
      }
      @keyframes sup {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .sname {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2rem, 3.3vw, 3.2rem);
        font-weight: 700;
        color: var(--w);
        line-height: 1.1;
        margin-bottom: 6px;
        word-break: break-word;
      }
      .sttl {
        font-size: 1rem;
        color: var(--gold);
        letter-spacing: 0.04em;
        margin-bottom: 20px;
      }
      .sdiv {
        width: 100px;
        height: 1.5px;
        background: linear-gradient(90deg, var(--gold), transparent);
        margin-bottom: 20px;
      }
      .itbl {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 24px;
      }
      .irow {
        display: flex;
        align-items: baseline;
        gap: 10px;
        font-size: 0.93rem;
      }
      .ilbl {
        color: var(--wd);
        width: 90px;
        flex-shrink: 0;
        font-size: 0.9rem;
      }
      .idot {
        color: var(--gold);
        font-size: 0.65rem;
        opacity: 0.75;
      }
      .ival {
        color: var(--w);
        font-weight: 500;
        font-size: 1rem;
      }
      .db {
        background: linear-gradient(
          135deg,
          rgba(212, 169, 67, 0.1) 0%,
          rgba(212, 169, 67, 0.04) 100%
        );
        border: 1px solid rgba(212, 169, 67, 0.2);
        border-radius: 14px;
        padding: 18px 22px;
        position: relative;
        overflow: hidden;
      }
      .db::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          rgba(212, 169, 67, 0.45),
          transparent
        );
      }
      .dtag {
        font-size: 0.65rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 5px;
      }
      .dval {
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--w);
        margin-bottom: 14px;
        font-family: "Cormorant Garamond", serif;
      }
      .mtag {
        font-size: 0.65rem;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 5px;
      }
      .mval {
        font-size: 0.9rem;
        color: var(--wm);
        font-style: italic;
        line-height: 1.6;
      }

      /* ── CONTROLS ── */
      .ctl {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 7px;
        /* Ganti fadeU menjadi fadeSimple agar properti transform tidak mengunci posisi tombol absolute */
        animation: fadeSimple 0.9s 0.4s ease both;
      }
      .crow {
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .tr {
        position: relative;
        width: 40px;
        height: 40px;
        cursor: pointer;
      }
      .tr svg {
        transform: rotate(-90deg);
      }
      .tt {
        fill: none;
        stroke: rgba(212, 169, 67, 0.2);
        stroke-width: 2.5;
      }
      .tf {
        fill: none;
        stroke: var(--gold);
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-dasharray: 97;
        stroke-dashoffset: 97;
        transition: stroke-dashoffset 0.1s linear;
      }
      .ti {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.76rem;
        color: var(--gold);
        user-select: none;
      }
      .tr:hover .ti {
        color: var(--gold-lt);
      }
      .dots {
        display: flex;
        gap: 6px;
        align-items: center;
      }
      .dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: rgba(212, 169, 67, 0.22);
        cursor: pointer;
        transition: all 0.3s ease;
      }
      .dot.a {
        background: var(--gold);
        width: 20px;
        border-radius: 3px;
        box-shadow: 0 0 8px rgba(212, 169, 67, 0.55);
      }
      .cnt {
        font-size: 0.72rem;
        color: var(--wd);
        letter-spacing: 0.12em;
        min-width: 40px;
        text-align: center;
      }
      .hint {
        font-size: 0.64rem;
        color: rgba(245, 240, 232, 0.28);
        letter-spacing: 0.05em;
        text-align: center;
      }

      /* ── FULLSCREEN BUTTON ── */
      .fs-btn {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        border: 1px solid rgba(212, 169, 67, 0.35);
        background: rgba(212, 169, 67, 0.07);
        color: var(--gold);
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        backdrop-filter: blur(12px);
        transition: all 0.25s ease;
        flex-shrink: 0;
      }
      .fs-btn:hover {
        background: var(--gold);
        color: var(--bg);
        border-color: var(--gold);
        transform: scale(1.08);
        box-shadow: 0 0 22px var(--glow);
      }
      .fs-btn:active {
        transform: scale(0.95);
      }
      .fs-btn svg {
        width: 15px;
        height: 15px;
        pointer-events: none;
      }

      /* ── FULLSCREEN TOAST ── */
      #fs-toast {
        position: fixed;
        top: 22px;
        left: 50%;
        transform: translateX(-50%) translateY(-6px);
        background: rgba(212, 169, 67, 0.12);
        border: 1px solid rgba(212, 169, 67, 0.3);
        color: var(--gold-lt);
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding: 7px 18px;
        border-radius: 24px;
        backdrop-filter: blur(14px);
        opacity: 0;
        pointer-events: none;
        transition:
          opacity 0.3s ease,
          transform 0.3s ease;
        z-index: 300;
        white-space: nowrap;
      }
      #fs-toast.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
      }

      /* ── KEYFRAMES ── */
      @keyframes fadeD {
        from {
          opacity: 0;
          transform: translateY(-18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes fadeU {
        from {
          opacity: 0;
          transform: translateY(18px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes fadeSimple {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 786px) {
        .pg {
          padding: 14px 10px 12px;
        }
        .sz {
          gap: 8px;
        }
        /* .nb {
          width: 34px;
          height: 34px;
          font-size: 0.8rem;
          flex-shrink: 0;
        } */
        .card {
          flex-direction: column;
        }
        .cp {
          width: 100%;
          height: 230px;
          flex-shrink: 0;
        }
        .cdv {
          display: none;
        }
        .ci {
          padding: 16px 20px 20px;
        }
        .photo-wrap {
          width: 165px;
          height: 165px;
        }
        .sname {
          font-size: 1.75rem;
        }
        .sttl {
          font-size: 0.8rem;
        }
        .irow {
          font-size: 0.85rem;
        }
        .ilbl {
          width: 80px;
          font-size: 0.76rem;
        }
        .ival {
          font-size: 0.87rem;
        }
        .dval {
          font-size: 0.95rem;
        }
        .mval {
          font-size: 0.82rem;
        }
        .orbit {
          inset: -8px;
        }
        header h1 {
          font-size: 1.25rem;
        }
        .badge {
          font-size: 0.72rem;
          letter-spacing: 0.2em;
        }
        .db {
          padding: 14px 16px;
        }
        .itbl {
          gap: 8px;
          margin-bottom: 16px;
        }
        .hint {
          display: none;
        }

        /* 1. Atur tombol panah agar ukurannya pas di handphone */
        .nb {
          position: static !important;
          transform: none !important;
          width: 44px;
          height: 44px;
          background: rgba(212, 169, 67, 0.12) !important;
